{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nabd Al-Gharb",
  "version": "1.0.0",
  "identifier": "com.nabdalgharb.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nabd Al-Gharb — Billing, Ledger & Inventory",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4Njk4QjJBMEVFNkYwRTcKUldUbjhPWU9Lb3RwZU94SHpsVldLNDVvTmt5Zk5JMTRhM2F2K05DVVpWVTRjSFRYaHZpNm1sRDMK",
      "endpoints": [
        "https://github.com/mohsin12043-design/NABDALGHARBDESKTOP/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
